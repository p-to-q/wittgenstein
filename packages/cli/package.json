{
  "name": "@wittgenstein/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Wittgenstein modality harness CLI — text-first LLMs emit typed code; deterministic codecs render image, audio, sensor, video artifacts with manifest receipts.",
  "keywords": [
    "multimodal",
    "cli",
    "image",
    "tts",
    "audio",
    "sensor",
    "llm"
  ],
  "homepage": "https://github.com/p-to-q/wittgenstein",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-to-q/wittgenstein.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/p-to-q/wittgenstein/issues"
  },
  "license": "Apache-2.0",
  "bin": {
    "wittgenstein": "./bin/wittgenstein.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "prepack": "pnpm run build",
    "release:npm": "pnpm run build && pnpm run bundle && node scripts/prepare-npm-artifact.mjs",
    "smoke": "node ./bin/wittgenstein.js doctor"
  },
  "dependencies": {
    "@wittgenstein/codec-video": "workspace:*",
    "@wittgenstein/core": "workspace:*",
    "@wittgenstein/schemas": "workspace:*",
    "commander": "^14.0.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "esbuild": "0.28.0"
  }
}
