{
  "name": "wittgenstein-monorepo",
  "private": true,
  "version": "0.3.0-alpha.3",
  "description": "Wittgenstein — harness-first multimodal runtime: text LLMs, typed codecs, traceable artifacts.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:deps": "node scripts/check-codec-boundaries.mjs",
    "lint:no-research-imports": "node scripts/check-no-research-imports.mjs",
    "lint:npm-publish-tarball": "node scripts/check-npm-publish-tarball.mjs",
    "lint:publish-surface": "pnpm lint:no-research-imports && pnpm lint:npm-publish-tarball",
    "test": "pnpm -r test",
    "test:golden": "pnpm -r --filter \"./packages/codec-*\" --if-present run test:golden",
    "test:image-adapter": "python3 python/image_adapter/test_train_numpy_smoke.py",
    "sweep:audio-kokoro": "tsx scripts/audio-kokoro-sweep.ts",
    "launch:check": "pnpm typecheck && pnpm --filter @wittgenstein/codec-audio test && pnpm --filter @wittgenstein/codec-sensor test",
    "benchmark": "node --import tsx benchmarks/harness.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "pnpm format:check:maintained",
    "format:check:maintained": "prettier --check \".github/**/*.{yml,yaml,md}\" \".github/*.yml\" \".github/*.md\" \".eslintrc.cjs\" \"package.json\" \".prettierrc\"",
    "format:check:full": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "new-adr": "tsx scripts/new-adr.ts",
    "train:audio-adapter": "node scripts/train-audio-ambient-adapter.mjs",
    "m1b:audit-self-check": "node scripts/m1b-audit-self-check.mjs",
    "m1b:audit-artifact-check": "node scripts/m1b-audit-artifact-check.mjs",
    "m1b:phase0b-ir-sensitivity": "tsx research/validation/phase0b_semantic_ir_sensitivity.ts",
    "m1b:staging-plan-check": "node scripts/m1b-staging-plan-check.mjs",
    "doctor": "pnpm --filter @wittgenstein/cli exec wittgenstein doctor",
    "release:npm-cli": "pnpm --filter @wittgenstein/cli run release:npm",
    "publish:npm-cli": "pnpm run release:npm-cli && npm publish packages/cli/npm-publish",
    "demo:audio": "pnpm --filter @wittgenstein/cli exec wittgenstein audio \"Hackathon launch voiceover with rain ambience\" --dry-run --ambient rain --out artifacts/demo/hackathon-launch.wav",
    "demo:tts": "pnpm --filter @wittgenstein/cli exec wittgenstein tts \"Hackathon voiceover for the Wittgenstein launch\" --dry-run --ambient city --out artifacts/demo/hackathon-tts.wav",
    "demo:sensor": "pnpm --filter @wittgenstein/cli exec wittgenstein sensor \"synthetic ecg trace for loupe dashboard\" --dry-run --out artifacts/demo/hackathon-sensor.json",
    "smoke:cli": "pnpm --filter @wittgenstein/cli run smoke",
    "reviewer-bench": "node --import tsx examples/reviewer-bench/run.ts",
    "dev:site": "pnpm --filter @wittgenstein/site dev",
    "dev:presentation": "pnpm --filter @wittgenstein/presentation dev"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.16",
      "@types/react-dom": "^19.2.3"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@wittgenstein/cli": "workspace:*",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
